rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }

    function isValidShare(data) {
      // 1 MiB limit for Firestore docs. Base64 is ~33% larger than binary.
      // So imageData should be roughly < 1,000,000 chars.
      return data.keys().hasAll(['id', 'imageData', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.id is string && data.id.size() <= 128 &&
             data.imageData is string && data.imageData.size() <= 1048576 &&
             data.createdAt == request.time;
    }

    match /shares/{shareId} {
      // Public view of shares via direct ID
      allow get: if isValidId(shareId);
      allow list: if false; 
      
      // Allow creation for authenticated users (anonymous allowed)
      allow create: if isSignedIn() && isValidShare(incoming()) && incoming().id == shareId;
      
      // No updates or deletes
      allow update, delete: if false;
    }
  }
}
